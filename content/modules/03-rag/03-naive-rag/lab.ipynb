<cell id="cell-0"><cell_type>markdown</cell_type># Lab 3.3 — Naive RAG in 50 lines
100 arXiv abstracts, fixed chunking, cosine retrieval, Claude generation.
Prereq: `bash data/download_arxiv.sh` (pulls 100 abstracts from arXiv API).
Cost: ~$0.08 per full run (12k tokens @ claude-sonnet-4-6).</cell id="cell-0">
<cell id="cell-1">!uv add anthropic voyageai numpy</cell id="cell-1">
<cell id="cell-2">import os, numpy as np, voyageai
from anthropic import Anthropic
from pathlib import Path
vo = voyageai.Client(); claude = Anthropic()

def chunk(t, size=500): return [t[i:i+size] for i in range(0, len(t), size)]

corpus = [(c, p.stem) for p in sorted(Path("data/arxiv").glob("*.txt")) for c in chunk(p.read_text())]
texts = [c for c,_ in corpus]
embs = np.array(vo.embed(texts, model="voyage-3", input_type="document").embeddings)
embs /= np.linalg.norm(embs, axis=1, keepdims=True)
print(f"indexed {len(corpus)} chunks from {len({d for _,d in corpus})} papers")</cell id="cell-2">
<cell id="cell-3">def retrieve(q, k=5):
    qe = np.array(vo.embed([q], model="voyage-3", input_type="query").embeddings[0])
    qe /= np.linalg.norm(qe)
    return [corpus[i] for i in (embs @ qe).argsort()[-k:][::-1]]

def ask(q):
    ctx = "\n\n---\n\n".join(c for c,_ in retrieve(q))
    r = claude.messages.create(model="claude-sonnet-4-6", max_tokens=400, temperature=0,
        messages=[{"role":"user","content":f"Context:\n{ctx}\n\nAnswer from context only: {q}"}])
    return r.content[0].text

print(ask("What is chain-of-thought prompting?"))</cell id="cell-3">
<cell id="cell-4"># recall@5 — the gate
import json
eval_set = json.loads(Path("data/eval_questions.json").read_text())
hits = 0
for item in eval_set:
    got = {aid for _,aid in retrieve(item["question"])}
    if item["expected_arxiv_id"] in got: hits += 1
print(f"recall@5 = {hits/len(eval_set):.2f}")</cell id="cell-4">
