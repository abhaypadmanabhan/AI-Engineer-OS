<cell id="cell-2"># 2. Smoke-test on 3 questions with seed 7.
import json
from pathlib import Path
from solution import build_corpus_index, load_filings, run_pipeline

filings = load_filings(Path("data/filings"))
qs = json.load(open("data/eval_questions.json"))["questions"][:3]
idx = build_corpus_index(filings, seed=7)
run = run_pipeline(idx, qs, seed=7)
for q, a in zip(run.questions, run.answers):
    print(f"\nQ: {q}\nA: {a[:300]}")</cell id="cell-2">
<cell id="cell-3"># 3. Full proxy eval — two seeds, mean ± stdev, asserts thresholds.
