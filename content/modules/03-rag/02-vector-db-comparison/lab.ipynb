<cell id="cell-0"><cell_type>markdown</cell_type># Lab 3.2 — Vector DB comparison
Qdrant (docker), pgvector (Postgres), Chroma (in-process). 1k vectors, 5-result queries.
Prereq: `docker compose up -d` with the compose file from the lesson.</cell id="cell-0">
<cell id="cell-1">!uv add qdrant-client pgvector psycopg[binary] chromadb numpy</cell id="cell-1">
<cell id="cell-2">import numpy as np
rng = np.random.default_rng(0)
vecs = rng.standard_normal((1000, 1024)).astype("float32")
vecs /= np.linalg.norm(vecs, axis=1, keepdims=True)
cats = [["cs.CL","cs.CV","cs.LG"][i % 3] for i in range(1000)]</cell id="cell-2">
<cell id="cell-3"># --- Qdrant ---
from qdrant_client import QdrantClient
from qdrant_client.models import Distance, VectorParams, PointStruct, Filter, FieldCondition, MatchValue
q = QdrantClient(url="http://localhost:6333")
q.recreate_collection("arxiv", vectors_config=VectorParams(size=1024, distance=Distance.COSINE))
q.upsert("arxiv", points=[PointStruct(id=i, vector=vecs[i].tolist(), payload={"category": cats[i]}) for i in range(1000)])
hits = q.search("arxiv", query_vector=vecs[0].tolist(),
                query_filter=Filter(must=[FieldCondition(key="category", match=MatchValue(value="cs.CL"))]), limit=5)
print("qdrant:", [(h.id, round(h.score,3)) for h in hits])</cell id="cell-3">
<cell id="cell-4"># --- pgvector ---
import psycopg
from pgvector.psycopg import register_vector
conn = psycopg.connect("postgresql://postgres:dev@localhost:5432/postgres", autocommit=True)
conn.execute("CREATE EXTENSION IF NOT EXISTS vector")
register_vector(conn)
conn.execute("DROP TABLE IF EXISTS arxiv")
conn.execute("CREATE TABLE arxiv (id int PRIMARY KEY, category text, emb vector(1024))")
with conn.cursor().copy("COPY arxiv (id, category, emb) FROM STDIN") as cp:
    for i in range(1000): cp.write_row((i, cats[i], vecs[i]))
conn.execute("CREATE INDEX ON arxiv USING hnsw (emb vector_cosine_ops)")
rows = conn.execute("SELECT id, 1-(emb <=> %s) AS score FROM arxiv WHERE category='cs.CL' ORDER BY emb <=> %s LIMIT 5",
                    (vecs[0], vecs[0])).fetchall()
print("pgvector:", rows)</cell id="cell-4">
<cell id="cell-5"># --- Chroma ---
import chromadb
c = chromadb.Client()
col = c.create_collection("arxiv_chroma", metadata={"hnsw:space": "cosine"})
col.add(ids=[str(i) for i in range(1000)], embeddings=vecs.tolist(),
        metadatas=[{"category": cats[i]} for i in range(1000)])
print("chroma:", col.query(query_embeddings=[vecs[0].tolist()], n_results=5, where={"category": "cs.CL"})["ids"])</cell id="cell-5">
<cell id="cell-6"># p95 latency bench on Qdrant
import time, statistics
queries = rng.standard_normal((100, 1024)).astype("float32"); queries /= np.linalg.norm(queries, axis=1, keepdims=True)
lat = []
for v in queries:
    t0 = time.perf_counter(); q.search("arxiv", query_vector=v.tolist(), limit=5)
    lat.append((time.perf_counter()-t0)*1000)
print(f"p95={statistics.quantiles(lat, n=20)[18]:.1f}ms")</cell id="cell-6">