<cell id="cell-2">from solution import fixed, recursive, semantic, structural_md, build_index, recall_at_k
for name, fn in [("fixed", fixed), ("recursive", recursive), ("semantic", semantic), ("structural_md", structural_md)]:
    embs, corpus = build_index(fn)
    print(f"{name:<14} recall@5={recall_at_k(embs, corpus, k=5):.2f}  chunks={len(corpus)}")</cell id="cell-2">
<cell id="cell-3"># Matrix of (chunker, size) — sweep the knob
from solution import build_index, recall_at_k
results = []
for size in (200, 500, 1000, 1500):
    fn = lambda t, s=size: fixed(t, size=s, overlap=int(s*0.1))
    embs, corpus = build_index(fn)
    r = recall_at_k(embs, corpus, k=5)
    results.append((size, len(corpus), r))
    print(f"size={size:>4}  chunks={len(corpus):>4}  recall@5={r:.2f}")</cell id="cell-3">
<cell id="cell-4"># Where recursive beats fixed — print pairs where winners diverge
from solution import build_index
import numpy as np, voyageai, json
from pathlib import Path
vo = voyageai.Client()
eval_set = json.loads((Path("..") / "03-naive-rag" / "data" / "eval_questions.json").read_text())
for name, fn in [("fixed", fixed), ("recursive", recursive)]:
    embs, corpus = build_index(fn)
    for item in eval_set[:5]:
        qe = np.array(vo.embed([item["question"]], model="voyage-3", input_type="query").embeddings[0])
        qe /= np.linalg.norm(qe)
        top = (embs @ qe).argsort()[-3:][::-1]
        print(f"[{name}] {item['question'][:50]!r}")
        for i in top: print(f"    ({corpus[i][1]})")
    print("---")</cell id="cell-4">