<cell id="cell-2">from solution import load_corpus, build_index, rrf, eval_config
corpus = load_corpus()
texts, E, bm25 = build_index(corpus)
print(f"{len(corpus)} chunks over {len({d for _,d in corpus})} papers")</cell id="cell-2">
<cell id="cell-3">import numpy as np, voyageai
vo = voyageai.Client()

def dense(q, k):
    qe = np.array(vo.embed([q], model="voyage-3", input_type="query").embeddings[0])
    qe /= np.linalg.norm(qe); return list(np.argsort(-(E @ qe))[:k])

def sparse(q, k):
    return list(np.argsort(-np.array(bm25.get_scores(q.lower().split())))[:k])

def hybrid(q, k):
    return rrf([np.array(dense(q, 50)), np.array(sparse(q, 50))], k)

q = "What is chain-of-thought prompting?"
print("dense   :", [corpus[i][1] for i in dense(q, 5)])
print("sparse  :", [corpus[i][1] for i in sparse(q, 5)])
print("hybrid  :", [corpus[i][1] for i in hybrid(q, 5)])</cell id="cell-3">
<cell id="cell-4">import os, cohere
co = cohere.Client()  # COHERE_API_KEY

def hybrid_rerank(q, k):
    cands = hybrid(q, 50)
    docs = [texts[i] for i in cands]
    r = co.rerank(query=q, documents=docs, model="rerank-v3.5", top_n=k)
    return [cands[x.index] for x in r.results]

print("hybrid+rr:", [corpus[i][1] for i in hybrid_rerank(q, 5)])</cell id="cell-4">
<cell id="cell-5">import json
