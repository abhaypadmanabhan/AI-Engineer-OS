<cell id="cell-2">from solution import load_corpus, build_index, rrf, eval_config
corpus = load_corpus()
texts, E, bm25 = build_index(corpus)
print(f"{len(corpus)} chunks over {len({d for _,d in corpus})} papers")</cell id="cell-2">
<cell id="cell-3">import numpy as np, cohere
co = cohere.Client(api_key=os.environ["COHERE_API_KEY"])

def dense(q, k):
    qe = np.array(co.embed(texts=[q], model="embed-english-v3.0", input_type="search_query").embeddings[0])
    qe /= np.linalg.norm(qe); return list(np.argsort(-(E @ qe))[:k])

def sparse(q, k):
    return list(np.argsort(-np.array(bm25.get_scores(q.lower().split())))[:k])

def hybrid(q, k):
    return rrf([np.array(dense(q, 50)), np.array(sparse(q, 50))], k)

q = "What is chain-of-thought prompting?"
print("dense   :", [corpus[i][1] for i in dense(q, 5)])
print("sparse  :", [corpus[i][1] for i in sparse(q, 5)])
print("hybrid  :", [corpus[i][1] for i in hybrid(q, 5)])</cell id="cell-3">
<cell id="cell-4"># Free local reranker — bge-reranker-v2-m3. First load downloads ~560MB.
from sentence_transformers import CrossEncoder
bge = CrossEncoder("BAAI/bge-reranker-v2-m3", max_length=512)

def rerank_bge(q, k):
    cands = hybrid(q, 50)
    pairs = [(q, texts[i]) for i in cands]
    scores = bge.predict(pairs)
    order = sorted(range(len(cands)), key=lambda i: -scores[i])[:k]
    return [cands[i] for i in order]

print("bge rerank:", [corpus[i][1] for i in rerank_bge(q, 5)])</cell id="cell-4">
<cell id="cell-5"># Paid production reranker — Cohere rerank-v3.5. Skip cell if no COHERE_API_KEY.
import os
if os.environ.get("COHERE_API_KEY"):
    import cohere
    co = cohere.Client()
    def rerank_cohere(q, k):
        cands = hybrid(q, 50)
        docs = [texts[i] for i in cands]
        r = co.rerank(query=q, documents=docs, model="rerank-v3.5", top_n=k)
        return [cands[x.index] for x in r.results]
    print("cohere rerank:", [corpus[i][1] for i in rerank_cohere(q, 5)])
else:
    print("set COHERE_API_KEY to run the paid reranker; bge fallback already ran above")</cell id="cell-5">
